{
  "name": "mysitebot-astro-template",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "sync-content": "rm -rf src/content/pages && mkdir -p src/content/pages && cp -r content/pages/. src/content/pages/",
    "dev": "npm run sync-content && astro dev",
    "build": "npm run sync-content && astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^4.11.0",
    "@astrojs/tailwind": "^5.1.0",
    "@astrojs/mdx": "^3.1.2",
    "tailwindcss": "^3.4.7",
    "yaml": "^2.5.0"
  }
}

---
import { readFileSync, existsSync } from 'fs';
import { parse as parseYaml } from 'yaml';
import { z } from 'astro:content';
import { resolvePath } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
  pageLayout?: 'default' | 'full' | 'sidebar';
}

// Every field carries .catch() so a single invalid value (e.g. a malformed
// contact email) falls back to its own default instead of failing the whole
// parse and silently discarding every user setting.
const settingsSchema = z.object({
  site: z.object({
    name: z.string().default("My Business").catch("My Business"),
    tagline: z.string().default("The best in the business").catch("The best in the business"),
    primaryColor: z.string().regex(/^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$/).default("#4f46e5").catch("#4f46e5"),
    bgEffect: z.union([z.string(), z.array(z.string())]).optional().default([]).catch([]),
    cta: z.object({
      label: z.string(),
      url: z.string(),
    }).optional().catch(undefined),
  }).default({}),
  contact: z.object({
    email: z.string().email().default("hello@example.com").catch("hello@example.com"),
    phone: z.string().optional().catch(undefined),
  }).default({}),
  navigation: z.array(z.object({
    label: z.string(),
    url: z.string(),
  })).default([]).catch([]),
  analytics: z.object({
    enabled: z.boolean().default(false).catch(false),
    website_id: z.string().default("").catch(""),
  }).default({}).catch({}),
});

const settingsPath = 'content/settings.yaml';
let settings = settingsSchema.parse({});

if (existsSync(settingsPath)) {
  try {
    const settingsRaw = readFileSync(settingsPath, 'utf-8');
    const parsed = parseYaml(settingsRaw);
    const result = settingsSchema.safeParse(parsed);
    if (result.success) {
      settings = result.data;
    } else {
      console.warn("Invalid settings.yaml structure, using default settings:", result.error.format());
    }
  } catch (e) {
    console.error("Error reading or parsing settings.yaml:", e);
  }
}

const { title, description, hideHeader = false, hideFooter = false, pageLayout = 'default' } = Astro.props;
const siteTitle = title ? `${title} | ${settings.site.name}` : settings.site.name;

// Header CTA. settings.site.cta overrides label + target; without one, the
// historical default ("Get Started" -> /contact) renders only when a contact
// page actually exists — a header button that 404s on every page is worse
// than no button.
const hasContactPage = existsSync('content/pages/contact.mdx') || existsSync('content/pages/contact.md');
const headerCta = settings.site.cta ?? (hasContactPage ? { label: 'Get Started', url: '/contact' } : null);

// Contact-form wiring. The build pipeline injects PUBLIC_MYSITEBOT_API (the
// backend base URL) and PUBLIC_MYSITEBOT_PROJECT_ID; when both are present the
// contact form POSTs real submissions to the backend, which emails the owner.
// Absent (e.g. local template dev), the form degrades to an optimistic confirmation.
const apiBase = (import.meta.env.PUBLIC_MYSITEBOT_API || '').replace(/\/$/, '');
const formProjectId = import.meta.env.PUBLIC_MYSITEBOT_PROJECT_ID || '';
const contactEndpoint = apiBase && formProjectId ? `${apiBase}/api/forms/contact` : '';

// Analytics beacon. The platform injects a single shared Cloudflare Web Analytics
// token (PUBLIC_MYSITEBOT_ANALYTICS_TOKEN) into every site; per-site traffic is
// separated by hostname at query time, so one token scales to all customers. A
// site may override with its own enabled+website_id.
const perSiteAnalyticsToken = settings.analytics.enabled ? settings.analytics.website_id : '';
const analyticsToken = perSiteAnalyticsToken || (import.meta.env.PUBLIC_MYSITEBOT_ANALYTICS_TOKEN || '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={resolvePath('/favicon.svg')} />
    <title>{siteTitle}</title>
    <meta name="description" content={description || settings.site.tagline} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description || settings.site.tagline} />
    {Astro.props.image && <meta property="og:image" content={Astro.props.image} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={description || settings.site.tagline} />
    {Astro.props.image && <meta property="twitter:image" content={Astro.props.image} />}
    {analyticsToken && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${analyticsToken}"}`}></script>
    )}
    {contactEndpoint && <meta name="mysitebot:form-endpoint" content={contactEndpoint} />}
    {formProjectId && <meta name="mysitebot:project-id" content={formProjectId} />}
  </head>
  <body class="bg-slate-50/50 text-gray-900 font-sans min-h-screen flex flex-col relative overflow-x-hidden">
    {/* Background Effects Support */}
    { (Array.isArray(settings.site.bgEffect) ? settings.site.bgEffect.includes('grid') : settings.site.bgEffect === 'grid') && (
      <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none select-none">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#e2e8f0_1px,transparent_1px),linear-gradient(to_bottom,#e2e8f0_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_50%,transparent_100%)] opacity-30"></div>
      </div>
    )}

    {pageLayout === 'sidebar' ? (
      <div class="flex flex-col md:flex-row min-h-screen">
        {!hideHeader && (
          <aside class="w-full md:w-64 bg-white border-r border-gray-100 p-6 flex flex-col z-20">
            <a href={resolvePath('/')} class="text-2xl font-black tracking-tight text-gray-900 mb-8 block">
              {settings.site.name}
            </a>
            <nav class="flex flex-col gap-4">
              {settings.navigation.map((nav) => (
                <a href={resolvePath(nav.url)} class="text-sm font-semibold text-gray-600 hover:text-indigo-600 transition-colors">
                  {nav.label}
                </a>
              ))}
            </nav>
            {headerCta && (
              <div class="mt-auto pt-8">
                <a href={resolvePath(headerCta.url)} class="bg-gray-900 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-gray-800 transition-all active:scale-95 shadow-lg shadow-gray-200 block text-center">
                  {headerCta.label}
                </a>
              </div>
            )}
          </aside>
        )}
        <main class="flex-grow">
          <slot />
          {!hideFooter && (
            <footer class="border-t border-gray-100/50 backdrop-blur-md px-6 py-12 bg-gray-50/50 mt-16">
              <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12">
                <div>
                  <a href={resolvePath('/')} class="text-2xl font-black tracking-tight text-gray-900 mb-6 block">
                    {settings.site.name}
                  </a>
                  <p class="text-gray-500 max-w-sm leading-relaxed">
                    {settings.site.tagline}
                  </p>
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 mb-6 uppercase text-xs tracking-widest">Contact</h4>
                  <p class="text-sm text-gray-600">{settings.contact.email}</p>
                  {settings.contact.phone && <p class="text-sm text-gray-600 mt-1">{settings.contact.phone}</p>}
                </div>
              </div>
              <div class="border-t border-gray-200 mt-12 pt-8 text-center text-xs text-gray-400">
                &copy; {new Date().getFullYear()} {settings.site.name}. All rights reserved.
              </div>
            </footer>
          )}
        </main>
      </div>
    ) : (
      <>
        {!hideHeader && (
          <header class="border-b border-gray-100/50 backdrop-blur-md px-6 py-4 flex items-center justify-between z-10">
            <a href={resolvePath('/')} class="text-2xl font-black tracking-tight text-gray-900 hover:text-indigo-600 transition-colors">
              {settings.site.name}
            </a>
            <nav class="hidden md:flex items-center gap-8">
              {settings.navigation.map((nav) => (
                <a href={resolvePath(nav.url)} class="text-sm font-semibold text-gray-600 hover:text-indigo-600 transition-colors">
                  {nav.label}
                </a>
              ))}
            </nav>
            {headerCta && (
              <div class="flex items-center gap-4">
                <a href={resolvePath(headerCta.url)} class="bg-gray-900 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-gray-800 transition-all active:scale-95 shadow-lg shadow-gray-200">
                  {headerCta.label}
                </a>
              </div>
            )}
          </header>
        )}

        <main class="flex-grow">
          <slot />
        </main>

        {!hideFooter && (
          <footer class="border-t border-gray-100/50 backdrop-blur-md px-6 py-12 bg-gray-50/50 mt-16 z-10">
            <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
              <div class="md:col-span-2">
                <a href={resolvePath('/')} class="text-2xl font-black tracking-tight text-gray-900 mb-6 block">
                  {settings.site.name}
                </a>
                <p class="text-gray-500 max-w-sm leading-relaxed">
                  {settings.site.tagline}
                </p>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 mb-6 uppercase text-xs tracking-widest">Navigation</h4>
                <div class="flex flex-col gap-4">
                  {settings.navigation.map((nav) => (
                    <a href={resolvePath(nav.url)} class="text-sm text-gray-600 hover:text-indigo-600 transition-colors">
                      {nav.label}
                    </a>
                  ))}
                </div>
              </div>
              <div>
                <h4 class="font-bold text-gray-900 mb-6 uppercase text-xs tracking-widest">Contact</h4>
                <p class="text-sm text-gray-600">{settings.contact.email}</p>
                {settings.contact.phone && <p class="text-sm text-gray-600 mt-1">{settings.contact.phone}</p>}
              </div>
            </div>
            <div class="border-t border-gray-200 mt-12 pt-8 text-center text-xs text-gray-400">
              &copy; {new Date().getFullYear()} {settings.site.name}. All rights reserved.
            </div>
          </footer>
        )}
      </>
    )}
    <style is:global>
      @keyframes pulseSlow {
        0%, 100% {
          transform: translate(0px, 0px) scale(1);
        }
        33% {
          transform: translate(40px, -60px) scale(1.15);
        }
        66% {
          transform: translate(-30px, 30px) scale(0.9);
        }
      }
      .animate-pulse-slow {
        animation: pulseSlow 18s infinite ease-in-out;
      }
    </style>
  </body>
</html>

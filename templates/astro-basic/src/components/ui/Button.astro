---
import { resolvePath } from '../../utils/paths';

interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'success' | 'danger' | 'unstyled';
  class?: string;
}

const { 
  href, 
  type = 'button', 
  variant = 'primary', 
  class: className = '', 
  ...rest 
} = Astro.props;

const baseStyles = "inline-flex justify-center items-center px-8 py-4 rounded-xl font-bold transition-all text-center cursor-pointer select-none active:scale-[0.98]";
// 'unstyled' applies the structural base only, with NO color classes — for
// callers that supply their own complete colors via `class`. Appended classes
// cannot reliably override a variant's colors (Tailwind resolves conflicts by
// stylesheet order, not class-attribute order), so color-customizing callers
// must start from a colorless variant.
const variantStyles = variant === 'secondary'
  ? "bg-white border-2 border-gray-200 text-gray-900 hover:border-gray-900"
  : variant === 'success'
    ? "bg-green-500 text-white hover:bg-green-600 shadow-lg shadow-green-200"
    : variant === 'danger'
      ? "bg-red-500 text-white hover:bg-red-600 shadow-lg shadow-red-200"
      : variant === 'unstyled'
        ? ""
        : "bg-indigo-600 text-white hover:bg-indigo-700 shadow-lg shadow-indigo-200";

const classes = `${baseStyles} ${variantStyles} ${className}`;
---

{href ? (
  <a href={resolvePath(href)} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}

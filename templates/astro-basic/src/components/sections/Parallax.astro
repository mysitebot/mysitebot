---
/**
 * Parallax Component - A multi-layer parallax scroll effect section.
 * Layers are stacked and drift at different speeds as the page scrolls to
 * create a sense of depth. Motion is JavaScript-driven but fully progressive:
 * the layers render in place with no script, the scroll effect is throttled to
 * the browser's paint cycle, and it is automatically disabled for visitors who
 * request reduced motion. Ideal for expressive hero bands and section breaks.
 */
interface Props {
  /** Optional ID for anchor linking */
  id?: string;
  /** Background color for the outer section (Tailwind class) */
  backgroundColor?: string;
  /** Text color for the section (Tailwind class) */
  textColor?: string;
  /** Array of parallax layers with content */
  layers: Array<{
    /** Text or content for this layer */
    content: string;
    /** Parallax depth/speed factor (0 = stationary, 1 = normal scroll, >1 = slower scroll) */
    depth?: number;
    /** Optional heading for the layer */
    heading?: string;
    /** Text color override for this layer (Tailwind class) */
    color?: string;
    /** Font size for the content (Tailwind class, e.g., 'text-xl', 'text-2xl') */
    fontSize?: string;
  }>;
  /** Minimum height for the parallax section (Tailwind class, default: 'min-h-96') */
  minHeight?: string;
}

const {
  id,
  backgroundColor = 'bg-gray-100',
  textColor = 'text-gray-900',
  layers = [],
  minHeight = 'min-h-96',
} = Astro.props;
---

<section
  {id}
  class={`parallax-section relative isolate overflow-hidden ${backgroundColor} ${textColor} ${minHeight}`}
  role="region"
  aria-label="Featured"
>
  <div class="relative h-full w-full">
    {layers.map((layer) => (
      <div
        class={`parallax-layer absolute inset-0 flex items-center justify-center px-6 will-change-transform ${
          layer.color || textColor
        }`}
        data-depth={layer.depth ?? 1}
      >
        <div class="max-w-3xl text-center text-balance">
          {layer.heading && (
            <h2 class={`${layer.fontSize || 'text-3xl sm:text-4xl'} font-bold tracking-tight mb-4`}>
              {layer.heading}
            </h2>
          )}
          <p class={`leading-relaxed ${layer.fontSize || 'text-lg sm:text-xl'}`}>
            {layer.content}
          </p>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  // Progressive parallax: layers already render in place, so this only adds the
  // scroll-linked drift. Work is batched into requestAnimationFrame and skipped
  // entirely for reduced-motion users or off-screen sections.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  document.querySelectorAll<HTMLElement>('.parallax-section').forEach((section) => {
    const layers = Array.from(
      section.querySelectorAll<HTMLElement>('.parallax-layer'),
    );
    if (!layers.length) return;

    let visible = false;
    let ticking = false;

    const render = () => {
      ticking = false;
      // Offset each layer relative to the section's own position in the
      // viewport so the effect is anchored to the section, not the page top.
      const progress = section.getBoundingClientRect().top;
      for (const layer of layers) {
        const depth = parseFloat(layer.dataset.depth || '1');
        layer.style.transform = `translate3d(0, ${progress * (1 - depth) * 0.3}px, 0)`;
      }
    };

    const reset = () => {
      for (const layer of layers) layer.style.transform = '';
    };

    const onScroll = () => {
      if (!visible || ticking) return;
      ticking = true;
      requestAnimationFrame(render);
    };

    const apply = () => {
      if (reduceMotion.matches) {
        window.removeEventListener('scroll', onScroll);
        reset();
        return;
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      render();
    };

    // Only listen while the section is on (or near) the screen.
    new IntersectionObserver((entries) => {
      visible = entries[0].isIntersecting;
      if (visible) render();
    }).observe(section);

    reduceMotion.addEventListener('change', apply);
    apply();
  });
</script>

---
/**
 * Parallax Component - A multi-layer parallax scroll effect section.
 * Ideal for creating depth and visual interest with layered content.
 */
interface Props {
  /** Optional ID for anchor linking */
  id?: string;
  /** Background color for the outer section (Tailwind class) */
  backgroundColor?: string;
  /** Text color for the section (Tailwind class) */
  textColor?: string;
  /** Array of parallax layers with content */
  layers: Array<{
    /** Text or content for this layer */
    content: string;
    /** Parallax depth/speed factor (0 = stationary, 1 = normal scroll, >1 = slower scroll) */
    depth?: number;
    /** Optional heading for the layer */
    heading?: string;
    /** Text color override for this layer (Tailwind class) */
    color?: string;
    /** Font size for the content (Tailwind class, e.g., 'text-xl', 'text-2xl') */
    fontSize?: string;
  }>;
  /** Minimum height for the parallax section (Tailwind class, default: 'min-h-96') */
  minHeight?: string;
}

const {
  id,
  backgroundColor = 'bg-gray-100',
  textColor = 'text-gray-900',
  layers = [],
  minHeight = 'min-h-96'
} = Astro.props;

// Calculate transform values for each layer based on depth
const getParallaxStyle = (depth: number = 1) => {
  return `transform: translateY(calc(var(--scroll-y) * ${1 - depth} * 0.5px));`;
};
---

<section {id} class={`${backgroundColor} ${textColor} ${minHeight} relative overflow-hidden`}>
  <script>
    // Parallax scroll effect
    let scrollY = 0;
    const updateParallax = () => {
      scrollY = window.scrollY;
      const parallaxLayers = document.querySelectorAll('.parallax-layer');
      parallaxLayers.forEach((layer) => {
        const depth = parseFloat(layer.getAttribute('data-depth') || '1');
        const offset = scrollY * (1 - depth) * 0.5;
        (layer as HTMLElement).style.transform = `translateY(${offset}px)`;
      });
    };
    window.addEventListener('scroll', updateParallax);
    updateParallax();
  </script>

  <div class="relative w-full h-full">
    {layers.map((layer, idx) => (
      <div
        class={`parallax-layer absolute inset-0 flex items-center justify-center transition-none ${
          layer.color || textColor
        }`}
        data-depth={layer.depth || 1}
      >
        <div class="text-center">
          {layer.heading && (
            <h2 class={`${layer.fontSize || 'text-2xl'} font-bold mb-4`}>
              {layer.heading}
            </h2>
          )}
          <p class={layer.fontSize || 'text-xl'}>
            {layer.content}
          </p>
        </div>
      </div>
    ))}
  </div>
</section>

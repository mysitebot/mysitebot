---
/**
 * Stats Component - A compact band of headline metrics ("10k+ customers",
 * "99.9% uptime", "24/7 support"). Ideal for building credibility on landing,
 * about, or investor pages. Each figure is rendered as an accessible
 * description list (value + label) so screen readers announce the pairing.
 */
interface Props {
  /** Optional anchor id for in-page links (e.g. href="#stats") */
  id?: string;
  /** Section heading */
  heading?: string;
  /** Supporting description shown below the heading */
  subheading?: string;
  /** Background color for the outer section (Tailwind class, e.g. 'bg-gray-50') */
  backgroundColor?: string;
  /** Base text color applied to heading and body text (Tailwind class, e.g. 'text-white'). Use when backgroundColor is dark. */
  textColor?: string;
  /** Override color for the metric values only (Tailwind class, e.g. 'text-indigo-600'). Takes precedence over textColor for the numbers. */
  valueColor?: string;
  /** Text alignment for the section header: 'center' (default), 'left', or 'right' */
  align?: 'left' | 'center' | 'right';
  /** Number of columns in the metrics grid (2, 3, or 4; default: 4) */
  columns?: 2 | 3 | 4;
  /** Visual treatment: 'plain' for dividers between figures (default), 'cards' for individually boxed figures */
  variant?: 'plain' | 'cards';
  /** Array of headline metrics */
  stats: Array<{
    /** The headline figure, formatted for display (e.g. '10k+', '99.9%', '$2.4M') */
    value: string;
    /** Short label describing the figure (e.g. 'Active users') */
    label: string;
    /** Optional one-line detail shown beneath the label */
    description?: string;
  }>;
}

const {
  id,
  heading,
  subheading,
  backgroundColor = 'bg-white',
  textColor,
  valueColor,
  align = 'center',
  columns = 4,
  variant = 'plain',
  stats = [],
} = Astro.props;

const alignClass = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right',
}[align];

const gridColsClass = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-2 lg:grid-cols-4',
}[columns] ?? 'grid-cols-2 lg:grid-cols-4';

// 'plain' figures sit flush and lean on thin dividers to separate them; 'cards'
// wrap each figure in its own rounded, bordered panel.
const isCards = variant === 'cards';
const itemClass = isCards
  ? 'flex flex-col-reverse items-center gap-2 rounded-3xl border border-gray-100 bg-white/60 p-8 shadow-sm text-center transition duration-300 hover:shadow-md hover:-translate-y-1'
  : 'flex flex-col-reverse items-center gap-2 px-6 py-4 text-center';
const listClass = isCards
  ? `grid grid-cols-1 ${gridColsClass} gap-6`
  : `grid grid-cols-1 ${gridColsClass} gap-y-12 gap-x-8`;
---

<section id={id} class={`py-24 px-6 ${backgroundColor} ${textColor ?? ''}`}>
  <div class="max-w-7xl mx-auto">
    {(heading || subheading) && (
      <div class={`${alignClass} mb-16`}>
        {heading && <h2 class={`text-4xl font-bold mb-4 ${textColor ?? 'text-gray-900'}`}>{heading}</h2>}
        {subheading && (
          <p class={`text-lg ${textColor ?? 'text-gray-500'} ${align === 'center' ? 'max-w-2xl mx-auto' : ''}`}>
            {subheading}
          </p>
        )}
      </div>
    )}

    <dl class={listClass}>
      {stats.map(stat => (
        <div class={itemClass}>
          {/* flex-col-reverse renders the value on top while keeping the term
              (label) before the definition (value) in DOM/reading order. */}
          <div>
            <dt class={`text-sm font-semibold uppercase tracking-wider ${textColor ?? 'text-gray-900'}`}>{stat.label}</dt>
            {stat.description && (
              <p class={`mt-1 text-sm leading-relaxed ${textColor ?? 'text-gray-500'}`}>{stat.description}</p>
            )}
          </div>
          <dd class={`text-4xl sm:text-5xl font-extrabold tracking-tight ${valueColor ?? textColor ?? 'text-indigo-600'}`}>
            {stat.value}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

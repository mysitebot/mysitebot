---
import { resolvePath } from '../../utils/paths';
/**
 * ContactForm Component - Property-Driven Architecture
 * Inspired by Fulldev UI for maximum AI-compatibility.
 */
interface Props {
  /** Optional anchor id for in-page links (e.g. href="#reservation") */
  id?: string;
  /** Tailwind background-color utility applied to the section (e.g. "bg-pink-50", "bg-white") */
  backgroundColor?: string;
  /** Tailwind text-color utility applied as the base text color (e.g. "text-white"). Use when backgroundColor is dark. */
  textColor?: string;
  /** Background image URL — creates a full-cover background with a subtle overlay */
  backgroundImage?: string;
  heading?: string;
  subheading?: string;
  email?: string;
  successMessage?: string;
  /** If true (default), wraps the form in a raised card container */
  card?: boolean;
  /** Background color for the card container (Tailwind class, e.g., 'bg-gray-50', 'bg-white'). Only applied when card=true. */
  cardBackgroundColor?: string;
  /** Label text for the submit button (e.g. "Send", "Submit", "Get in touch") */
  buttonLabel?: string;
  buttonVariant?: 'primary' | 'secondary' | 'success' | 'danger';
  /** Text alignment for heading and subheading: 'left' (default), 'center', or 'right' */
  align?: 'left' | 'center' | 'right';
  layout?: 'centered' | 'split';
  /** Max width constraint for the form container (Tailwind class, e.g., 'max-w-sm', 'max-w-md') */
  maxWidth?: string;
  /** If true, the form section takes up at least the full height of the screen (useful with backgroundImage) */
  fullHeight?: boolean;
  sidebar?: {
    title?: string;
    content?: string;
    address?: string[];
    phone?: string;
    email?: string;
  };
  fields?: Array<{
    label: string;
    /** Input type; use 'password' for masked credential fields; use 'select' for dropdown fields; use 'date' or 'time' for date/time pickers; use 'number' for numeric inputs */
    type: 'text' | 'email' | 'textarea' | 'password' | 'select' | 'date' | 'time' | 'number';
    required?: boolean;
    placeholder?: string;
    /** Options for select field type */
    options?: string[];
  }>;
  /** Optional image shown in the right column when layout='split' */
  image?: {
    src: string;
    alt?: string;
  };
}

import Input from '../ui/Input.astro';
import Textarea from '../ui/Textarea.astro';
import Button from '../ui/Button.astro';

const {
  id,
  backgroundColor = '',
  textColor = '',
  backgroundImage,
  card = true,
  cardBackgroundColor = 'bg-gray-50',
  heading = "Get in touch",
  subheading = "Fill out the form below and we'll get back to you soon.",
  email,
  successMessage = "Thanks! We've received your message.",
  buttonLabel = 'Send Message',
  buttonVariant = 'primary',
  align = 'left',
  layout = 'centered',
  maxWidth = 'max-w-3xl',
  fullHeight = false,
  sidebar,
  image,
  fields = [
    { label: "Name", type: "text", required: true },
    { label: "Email", type: "email", required: true },
    { label: "Message", type: "textarea", required: true }
  ]
} = Astro.props;

// Unique prefix so each field's <label for> targets its own control, even when
// several ContactForm sections (or repeated labels) appear on the same page.
const uid = `contact-${Math.random().toString(36).slice(2, 8)}`;

// Native <select> styled to match the library's Input component so dropdowns
// sit flush with the other fields.
const selectClass = 'block w-full rounded-xl border border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-4 text-gray-700 transition-colors focus:outline-none';
---

<section id={id} class={`${backgroundImage ? 'bg-cover bg-center relative' : ''} ${fullHeight ? 'min-h-screen flex items-center justify-center' : 'py-24'} px-6 ${backgroundColor} ${textColor}`} style={backgroundImage ? `background-image: url('${backgroundImage}')` : undefined}>
  {backgroundImage && <div class="absolute inset-0 bg-black bg-opacity-40 pointer-events-none" />}
  <div class={`${maxWidth || 'max-w-7xl'} mx-auto ${layout === 'split' ? 'grid md:grid-cols-2 gap-16' : ''} ${backgroundImage ? 'relative z-10' : ''}`}>
    <div class={layout === 'centered' ? maxWidth ? '' : 'max-w-3xl mx-auto' : ''}>
      <div class={`${card ? `${cardBackgroundColor} rounded-3xl p-8 md:p-16 border border-gray-100 shadow-sm` : ''} contact-form-container h-full`}>
        <div class={`mb-10 ${align === 'center' ? 'text-center' : align === 'right' ? 'text-right' : 'text-left'}`}>
          <h2 class="text-4xl font-bold text-gray-900 mb-4">{heading}</h2>
          <p class="text-lg text-gray-500">{subheading}</p>
        </div>

        <div class="success-message hidden mb-6 p-4 rounded-xl bg-green-50 border border-green-200 text-green-800 text-center font-semibold">
          {successMessage}
        </div>
        
        <form class="space-y-6" data-contact-form>
          {fields.map((field, i) => {
            const fieldId = `${uid}-${i}`;
            return (
            <div>
              <label for={fieldId} class="block text-sm font-semibold text-gray-700 mb-2">{field.label}</label>
              {field.type === 'textarea' ? (
                <Textarea
                  id={fieldId}
                  name={field.label}
                  placeholder={field.placeholder}
                  required={field.required}
                />
              ) : field.type === 'select' ? (
                <select id={fieldId} name={field.label} class={selectClass} required={field.required}>
                  {field.options?.map(option => (
                    <option value={option}>{option}</option>
                  ))}
                </select>
              ) : (
                <Input
                  id={fieldId}
                  type={field.type}
                  name={field.label}
                  placeholder={field.placeholder}
                  required={field.required}
                />
              )}
            </div>
            );
          })}

          {/* Honeypot: hidden from humans; bots that fill it are silently dropped server-side. */}
          <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true"
            class="hidden" style="position:absolute;left:-9999px;" />

          <Button type="submit" variant={buttonVariant} class="w-full">
            {buttonLabel}
          </Button>
          <p class="error-message hidden text-sm text-red-600 text-center" role="alert"></p>
        </form>
        
        {email && !sidebar && (
          <div class="mt-10 pt-10 border-t border-gray-100 text-center">
            <p class="text-sm text-gray-400">
              Prefer email? <a href={`mailto:${email}`} class="text-indigo-600 font-semibold hover:underline">{email}</a>
            </p>
          </div>
        )}
      </div>
    </div>

    {layout === 'split' && (
      <div class="flex flex-col justify-center space-y-12">
        {image && (
          <img src={resolvePath(image.src)} alt={image.alt ?? ''} class="rounded-2xl object-cover w-full h-full max-h-96" />
        )}
        {sidebar && (
          <div class="space-y-8">
            {sidebar.title && <h3 class="text-3xl font-bold text-gray-900">{sidebar.title}</h3>}
            {sidebar.content && <p class="text-xl text-gray-500 leading-relaxed">{sidebar.content}</p>}
            
            <div class="space-y-6">
              {sidebar.address && (
                <div class="flex items-start gap-4">
                  <div class="p-3 bg-indigo-50 text-indigo-600 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-gray-900 mb-1">Visit us</h4>
                    {sidebar.address.map(line => <p class="text-gray-500">{line}</p>)}
                  </div>
                </div>
              )}

              {sidebar.phone && (
                <div class="flex items-start gap-4">
                  <div class="p-3 bg-indigo-50 text-indigo-600 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-gray-900 mb-1">Call us</h4>
                    <p class="text-gray-500">{sidebar.phone}</p>
                  </div>
                </div>
              )}

              {(sidebar.email || email) && (
                <div class="flex items-start gap-4">
                  <div class="p-3 bg-indigo-50 text-indigo-600 rounded-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-gray-900 mb-1">Email us</h4>
                    <p class="text-gray-500">{sidebar.email || email}</p>
                  </div>
                </div>
              )}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</section>

<script>
  const endpoint = document.querySelector('meta[name="mysitebot:form-endpoint"]')?.getAttribute('content') || '';
  const projectId = document.querySelector('meta[name="mysitebot:project-id"]')?.getAttribute('content') || '';

  document.querySelectorAll('.contact-form-container').forEach(container => {
    const form = container.querySelector('[data-contact-form]') as HTMLFormElement | null;
    const successMsg = container.querySelector('.success-message');
    const errorMsg = container.querySelector('.error-message');
    if (!form || !successMsg) return;

    const showSuccess = () => {
      form.reset();
      errorMsg?.classList.add('hidden');
      successMsg.classList.remove('hidden');
      successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };
    const showError = (msg: string) => {
      if (errorMsg) { errorMsg.textContent = msg; errorMsg.classList.remove('hidden'); }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // Not wired to a backend (e.g. local template preview): keep the optimistic
      // confirmation rather than erroring.
      if (!endpoint || !projectId) { showSuccess(); return; }

      const data = new FormData(form);
      data.append('project_id', projectId);
      const submitBtn = form.querySelector('[type="submit"]') as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;
      try {
        const res = await fetch(endpoint, { method: 'POST', body: data });
        if (res.ok) showSuccess();
        else showError("Sorry, your message could not be sent. Please try again.");
      } catch {
        showError("Sorry, your message could not be sent. Please try again.");
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  });
</script>

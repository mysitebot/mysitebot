---
import { resolvePath } from '../../utils/paths';

/**
 * HeroCarousel Component - Full-screen background slideshow with content.
 * Slides auto-advance with a pure-CSS animation (no JavaScript). The animation
 * is disabled for visitors who prefer reduced motion, who instead see the first
 * slide statically — keeping the section accessible and WCAG-friendly.
 */
interface Props {
  /** Optional anchor id for in-page links (e.g. href="#featured") */
  id?: string;
  /** Ordered list of slides shown in the background slideshow */
  slides: Array<{
    /** Prominent headline shown centered over the slide image */
    heading: string;
    /** Optional supporting line shown below the heading */
    subheading?: string;
    /** Background image URL for the slide */
    image: string;
    /** Accessible alt text for the image; defaults to '' (treated as decorative since the heading carries the meaning) */
    alt?: string;
    /** Optional call-to-action button */
    action?: { label: string; href: string };
  }>;
  /** Tailwind height class for the carousel (default: 'h-screen'; e.g. 'h-[32rem]', 'h-[70vh]') */
  heightClass?: string;
  /** Background color shown behind slide images (Tailwind class, default: 'bg-black') */
  backgroundColor?: string;
  /** Tailwind classes for the readability overlay layered over each image (default: a bottom-weighted dark gradient) */
  overlayClass?: string;
  /** Horizontal alignment of slide content: 'center' (default), 'left', or 'right' */
  align?: 'left' | 'center' | 'right';
  /** Seconds each slide stays on screen before advancing (default: 5) */
  secondsPerSlide?: number;
}

const {
  id,
  slides = [],
  heightClass = 'h-screen',
  backgroundColor = 'bg-black',
  overlayClass = 'bg-gradient-to-t from-black/70 via-black/40 to-black/20',
  align = 'center',
  secondsPerSlide = 5,
} = Astro.props;

// Horizontal placement of the content block + text alignment; vertical
// centering is applied separately so content stays centered on the cross axis.
const alignClass = {
  left: 'justify-start text-left',
  center: 'justify-center text-center',
  right: 'justify-end text-right',
}[align];
const itemsClass = {
  left: 'items-start',
  center: 'items-center',
  right: 'items-end',
}[align];

const animate = slides.length > 1;
// Each slide holds for ~80% of its slot, then slides to the next.
const duration = slides.length * Math.max(secondsPerSlide, 1);
const keyframes = slides.map((_, i) => `
  ${(i / slides.length) * 100}% { transform: translateX(-${i * 100}%); }
  ${((i + 0.8) / slides.length) * 100}% { transform: translateX(-${i * 100}%); }
`).join('\n') + '100% { transform: translateX(0); }';
---

<section
  id={id}
  class={`relative ${heightClass} w-full overflow-hidden ${backgroundColor}`}
  role="region"
  aria-roledescription="carousel"
  aria-label="Highlights"
>
  <div class={`absolute inset-0 z-0 flex ${animate ? 'animate-slideshow' : ''}`}>
    {slides.map((slide, i) => (
      <div
        class="relative min-w-full h-full"
        role="group"
        aria-roledescription="slide"
        aria-label={`${i + 1} of ${slides.length}`}
      >
        <img
          src={resolvePath(slide.image)}
          alt={slide.alt ?? ''}
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div aria-hidden="true" class={`absolute inset-0 ${overlayClass}`}></div>
        <div class={`absolute inset-0 flex items-center p-6 sm:p-10 ${alignClass}`}>
          <div class={`max-w-4xl flex flex-col ${itemsClass}`}>
            <h2 class="text-4xl sm:text-6xl md:text-8xl font-black text-white mb-6 drop-shadow-lg text-balance">{slide.heading}</h2>
            {slide.subheading && <p class="text-lg sm:text-xl md:text-2xl text-gray-100 mb-10 drop-shadow-md max-w-2xl">{slide.subheading}</p>}
            {slide.action && (
              <a
                href={resolvePath(slide.action.href)}
                class="inline-flex items-center bg-white text-black px-10 py-4 rounded-full font-bold text-lg shadow-lg transition-transform hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-white/60"
              >
                {slide.action.label}
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  {animate && (
    <style is:inline set:html={`
      .animate-slideshow {
        animation: hero-carousel-slide ${duration}s infinite;
      }
      @keyframes hero-carousel-slide {
        ${keyframes}
      }
      @media (prefers-reduced-motion: reduce) {
        .animate-slideshow { animation: none; }
      }
    `}>
    </style>
  )}
</section>

---
import { resolvePath } from '../../utils/paths';
/**
 * Banner Component - A horizontal bar for notifications, secondary CTAs, or brand highlighting.
 */
interface Props {
  /** Optional anchor id for in-page links (e.g. href="#promo") */
  id?: string;
  /** The text content of the banner */
  text: string;
  /** Optional background color (Tailwind class) */
  backgroundColor?: string;
  /** Optional text color (Tailwind class) */
  textColor?: string;
  /** Optional link/CTA */
  action?: {
    label: string;
    href: string;
  };
  /** If true, the banner is fixed to the top of the viewport */
  sticky?: boolean;
  /** Position for fixed banners: 'top' (default) or 'bottom' */
  fixedPosition?: 'top' | 'bottom';
  /** Text alignment: 'left', 'center' (default), or 'right' */
  align?: 'left' | 'center' | 'right';
}

const {
  id,
  text,
  backgroundColor = 'bg-indigo-600',
  textColor = 'text-white',
  action,
  sticky = false,
  fixedPosition = 'top',
  align = 'center'
} = Astro.props;

const alignClass = align === 'left' ? 'justify-start' : align === 'right' ? 'justify-end' : 'justify-center';
---

<div id={id} class={`${backgroundColor} ${textColor} py-3 px-6 ${align === 'center' ? 'text-center' : align === 'left' ? 'text-left' : 'text-right'} ${sticky ? (fixedPosition === 'bottom' ? 'fixed bottom-0 left-0 right-0 z-50' : 'sticky top-0 z-50') : ''}`}>
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center ${alignClass} gap-4">
    <p class="font-medium">
      {text}
    </p>
    {action && (
      <a 
        href={resolvePath(action.href)} 
        class="bg-white text-indigo-600 px-4 py-1 rounded-full text-sm font-bold hover:bg-gray-100 transition-colors"
      >
        {action.label}
      </a>
    )}
  </div>
</div>

---
import { resolvePath } from '../../utils/paths';
import Button from '../ui/Button.astro';
/**
 * Gallery Component - Property-Driven Architecture
 */
interface Props {
  /** Optional anchor id for in-page links (e.g. href="#gallery") */
  id?: string;
  /** Background color for the section (Tailwind class, e.g. 'bg-gray-100') */
  backgroundColor?: string;
  /** Text color for heading and subheading (Tailwind class, e.g. 'text-white'). Use when backgroundColor is dark. */
  textColor?: string;
  /** Specific heading color override (Tailwind class, e.g. 'text-pink-500'). Takes precedence over textColor for the heading. */
  headingColor?: string;
  heading?: string;
  subheading?: string;
  columns?: 2 | 3 | 4;
  layout?: 'stacked' | 'split';
  /** Optional sidebar content */
  sidebar?: {
    title?: string;
    content?: string;
    image?: { src: string; alt: string; };
    links?: Array<{ label: string; href: string; }>;
    action?: { label: string; href: string; };
  };
  /** Text alignment for heading and subheading: 'center' (default), 'left', or 'right' — mirrors Hero.align */
  align?: 'left' | 'center' | 'right';
  /** Background image URL — creates a full-cover background with a subtle overlay */
  backgroundImage?: string;
  /** Optional CTA button rendered below the image grid */
  action?: { label: string; href: string; variant?: 'primary' | 'secondary' | 'success'; };
  /** Max width constraint (Tailwind class, e.g., 'max-w-3xl') */
  maxWidth?: string;
  images: Array<{
    src: string;
    alt: string;
    caption?: string;
    title?: string;
    description?: string;
    artist?: string;
    overlayText?: string;
    overlayPosition?: 'center' | 'top' | 'bottom';
    action?: { label: string; href: string; variant?: 'primary' | 'secondary' | 'success'; };
  }>;
}

const {
  id,
  heading,
  subheading,
  images = [],
  columns = 3,
  layout = 'stacked',
  sidebar,
  backgroundColor = '',
  textColor = '',
  headingColor = '',
  align = 'center',
  backgroundImage,
  action,
  maxWidth = 'max-w-7xl'
} = Astro.props;

const gridCols: Record<number, string> = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-3',
  4: 'md:grid-cols-4'
};
const colsClass = gridCols[columns] || 'md:grid-cols-3';

// Full class names (not interpolated) so Tailwind reliably emits them.
const overlayAlign = {
  top: 'items-start',
  center: 'items-center',
  bottom: 'items-end'
};
---

<section
  id={id}
  class={`py-20 px-6 ${backgroundColor} ${backgroundImage ? 'bg-cover bg-center relative' : ''}`}
  style={backgroundImage ? `background-image: url('${backgroundImage}')` : undefined}
>
  {backgroundImage && <div class="absolute inset-0 bg-black/30 pointer-events-none" />}
  <div class={`${maxWidth} mx-auto flex relative z-10 ${sidebar ? 'flex-col lg:flex-row gap-12' : layout === 'split' ? 'flex-col md:flex-row gap-12' : 'flex-col'}`}>
    {sidebar && (
      <aside class="w-full lg:w-1/4 flex-shrink-0">
        <div class="sticky top-24 space-y-6">
          {sidebar.title && <h3 class={`text-2xl font-bold ${textColor || 'text-gray-900'}`}>{sidebar.title}</h3>}
          {sidebar.content && <p class={`${textColor || 'text-gray-600'}`}>{sidebar.content}</p>}
          {sidebar.image && <img src={resolvePath(sidebar.image.src)} alt={sidebar.image.alt} class="w-full rounded-lg" />}
          {sidebar.links && (
            <ul class="space-y-3">
              {sidebar.links.map(link => (
                <li>
                  <a href={resolvePath(link.href)} class={`text-sm ${textColor || 'text-gray-600'} hover:text-indigo-600 transition-colors`}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
          {sidebar.action && (
            /* Button resolves the base path itself. */
            <Button href={sidebar.action.href} variant="primary" class="w-full text-sm px-5 py-2.5">
              {sidebar.action.label}
            </Button>
          )}
        </div>
      </aside>
    )}

    <div class={`${sidebar ? 'w-full lg:w-3/4' : layout === 'split' ? 'w-full md:w-3/4' : 'w-full'}`}>
      {(heading || subheading) && (
        <div class={`w-full mb-12 ${align === 'left' ? 'text-left' : align === 'right' ? 'text-right' : 'text-center'}`}>
          {heading && <h2 class={`text-3xl font-bold mb-4 ${headingColor || textColor || 'text-gray-900'}`}>{heading}</h2>}
          {subheading && <p class={`text-lg ${textColor || 'text-gray-500'}`}>{subheading}</p>}
        </div>
      )}

      <div class={`grid gap-6 grid-cols-1 sm:grid-cols-2 ${colsClass}`}>
        {images.map(img => {
          const hasBody = img.title || img.description || img.artist || img.caption || img.action;
          return (
          <figure class="group relative flex flex-col h-full overflow-hidden rounded-2xl bg-white shadow-md transition-shadow duration-300 hover:shadow-xl">
            <div class="relative aspect-video overflow-hidden bg-gray-100">
              <img
                src={resolvePath(img.src)}
                alt={img.alt}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              {img.overlayText && (
                <figcaption class={`absolute inset-0 flex justify-center bg-gradient-to-t from-black/70 via-black/20 to-transparent p-4 ${overlayAlign[img.overlayPosition ?? 'center'] ?? overlayAlign.center}`}>
                  <p class="text-center text-sm font-medium text-white drop-shadow md:text-base">{img.overlayText}</p>
                </figcaption>
              )}
            </div>
            {hasBody && (
              <div class="flex flex-1 flex-col p-5">
                {img.title && <h3 class="mb-2 text-lg font-semibold text-gray-900">{img.title}</h3>}
                {img.description && <p class="mb-3 flex-1 text-sm leading-relaxed text-gray-600">{img.description}</p>}
                {img.artist && <p class="text-sm font-medium text-indigo-600">{img.artist}</p>}
                {img.caption && <p class="mt-1 text-sm text-gray-500">{img.caption}</p>}
                {img.action && (
                  <div class="mt-4">
                    {/* Button resolves the base path itself. */}
                    <Button href={img.action.href} variant={img.action.variant || 'primary'} class="px-5 py-2.5 text-sm">
                      {img.action.label}
                    </Button>
                  </div>
                )}
              </div>
            )}
          </figure>
          );
        })}
      </div>
      {action && (
        <div class={`mt-10 ${align === 'left' ? 'text-left' : align === 'right' ? 'text-right' : 'text-center'}`}>
          {/* Button resolves the base path itself. */}
          <Button href={action.href} variant={action.variant || 'primary'}>
            {action.label}
          </Button>
        </div>
      )}
    </div>
  </div>
</section>

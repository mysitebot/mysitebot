---
import { resolvePath } from '../../utils/paths';
/**
 * Gallery Component - Property-Driven Architecture
 */
interface Props {
  /** Optional anchor id for in-page links (e.g. href="#gallery") */
  id?: string;
  /** Background color for the section (Tailwind class, e.g. 'bg-gray-100') */
  backgroundColor?: string;
  /** Text color for heading and subheading (Tailwind class, e.g. 'text-white'). Use when backgroundColor is dark. */
  textColor?: string;
  /** Specific heading color override (Tailwind class, e.g. 'text-pink-500'). Takes precedence over textColor for the heading. */
  headingColor?: string;
  heading?: string;
  subheading?: string;
  columns?: 2 | 3 | 4;
  layout?: 'stacked' | 'split';
  /** Optional sidebar content */
  sidebar?: {
    title?: string;
    content?: string;
    image?: { src: string; alt: string; };
    links?: Array<{ label: string; href: string; }>;
    action?: { label: string; href: string; };
  };
  /** Text alignment for heading and subheading: 'center' (default), 'left', or 'right' — mirrors Hero.align */
  align?: 'left' | 'center' | 'right';
  /** Background image URL — creates a full-cover background with a subtle overlay */
  backgroundImage?: string;
  /** Optional CTA button rendered below the image grid */
  action?: { label: string; href: string; variant?: 'primary' | 'secondary' | 'success'; };
  /** Max width constraint (Tailwind class, e.g., 'max-w-3xl') */
  maxWidth?: string;
  images: Array<{
    src: string;
    alt: string;
    caption?: string;
    title?: string;
    description?: string;
    artist?: string;
    overlayText?: string;
    overlayPosition?: 'center' | 'top' | 'bottom';
    action?: { label: string; href: string; variant?: 'primary' | 'secondary' | 'success'; };
  }>;
}

const {
  id,
  heading,
  subheading,
  images = [],
  columns = 3,
  layout = 'stacked',
  sidebar,
  backgroundColor = '',
  textColor = '',
  headingColor = '',
  align = 'center',
  backgroundImage,
  action,
  maxWidth = 'max-w-7xl'
} = Astro.props;

const gridCols: Record<number, string> = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-3',
  4: 'md:grid-cols-4'
};
const colsClass = gridCols[columns] || 'md:grid-cols-3';
---

<section
  id={id}
  class={`py-20 px-6 ${backgroundColor} ${backgroundImage ? 'bg-cover bg-center relative' : ''}`}
  style={backgroundImage ? `background-image: url('${backgroundImage}')` : undefined}
>
  {backgroundImage && <div class="absolute inset-0 bg-black bg-opacity-30 pointer-events-none" />}
  <div class={`${maxWidth} mx-auto flex relative z-10 ${sidebar ? 'flex-col lg:flex-row gap-12' : layout === 'split' ? 'flex-col md:flex-row gap-12' : 'flex-col'}`}>
    {sidebar && (
      <aside class="w-full lg:w-1/4 flex-shrink-0">
        <div class="sticky top-24 space-y-6">
          {sidebar.title && <h3 class={`text-2xl font-bold ${textColor || 'text-gray-900'}`}>{sidebar.title}</h3>}
          {sidebar.content && <p class={`${textColor || 'text-gray-600'}`}>{sidebar.content}</p>}
          {sidebar.image && <img src={resolvePath(sidebar.image.src)} alt={sidebar.image.alt} class="w-full rounded-lg" />}
          {sidebar.links && (
            <ul class="space-y-3">
              {sidebar.links.map(link => (
                <li>
                  <a href={resolvePath(link.href)} class={`text-sm ${textColor || 'text-gray-600'} hover:text-indigo-600 transition-colors`}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
          {sidebar.action && (
            <a href={resolvePath(sidebar.action.href)} class="inline-block bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded transition-colors">
              {sidebar.action.label}
            </a>
          )}
        </div>
      </aside>
    )}

    <div class={`${sidebar ? 'w-full lg:w-3/4' : layout === 'split' ? 'w-full md:w-3/4' : 'w-full'}`}>
      {(heading || subheading) && (
        <div class={`w-full mb-12 ${align === 'left' ? 'text-left' : align === 'right' ? 'text-right' : 'text-center'}`}>
          {heading && <h2 class={`text-3xl font-bold mb-4 ${headingColor || textColor || 'text-gray-900'}`}>{heading}</h2>}
          {subheading && <p class={`text-lg ${textColor || 'text-gray-500'}`}>{subheading}</p>}
        </div>
      )}

      <div class={`grid gap-6 grid-cols-1 sm:grid-cols-2 ${colsClass}`}>
        {images.map(img => (
          <div class="group relative overflow-hidden rounded-2xl bg-white shadow-md hover:shadow-xl transition-shadow h-full flex flex-col">
            <div class="relative overflow-hidden aspect-video bg-gray-100">
              <img
                src={resolvePath(img.src)}
                alt={img.alt}
                class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-110"
              />
              {img.overlayText && (
                <div class={`absolute inset-0 bg-black/50 flex items-${img.overlayPosition === 'top' ? 'start' : img.overlayPosition === 'bottom' ? 'end' : 'center'} justify-center p-4`}>
                  <p class="text-white text-center text-sm md:text-base">{img.overlayText}</p>
                </div>
              )}
            </div>
            <div class="p-4 flex-1 flex flex-col">
              {img.title && <h3 class="text-xl font-medium mb-2 text-gray-900">{img.title}</h3>}
              {img.description && <p class="text-gray-700 mb-3 flex-1">{img.description}</p>}
              {img.artist && <p class="text-sm text-gray-500">{img.artist}</p>}
              {img.caption && <p class="text-sm text-gray-600 mt-2">{img.caption}</p>}
              {img.action && (
                <a href={resolvePath(img.action.href)} class={`mt-4 inline-block px-3 py-2 text-xs font-bold uppercase rounded transition-colors ${
                  img.action.variant === 'secondary' ? 'bg-gray-200 text-gray-900 hover:bg-gray-300' :
                  img.action.variant === 'success' ? 'bg-green-500 text-white hover:bg-green-600' :
                  'bg-indigo-500 text-white hover:bg-indigo-600'
                }`}>
                  {img.action.label}
                </a>
              )}
            </div>
            {(img.title || img.artist || img.caption) && (
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-center items-center text-center p-6">
                {img.title && <p class="text-white text-2xl font-bold">{img.title}</p>}
                {img.artist && <p class="text-white text-lg">{img.artist}</p>}
                {img.caption && <p class="text-white text-sm font-medium">{img.caption}</p>}
              </div>
            )}
          </div>
        ))}
      </div>
      {action && (
        <div class={`mt-8 ${align === 'left' ? 'text-left' : align === 'right' ? 'text-right' : 'text-center'}`}>
          <a href={resolvePath(action.href)} class={`inline-block font-bold py-2 px-4 rounded transition-colors ${
            action.variant === 'secondary' ? 'bg-gray-200 text-gray-900 hover:bg-gray-300' :
            action.variant === 'success' ? 'bg-green-500 text-white hover:bg-green-600' :
            'bg-red-500 text-white hover:bg-red-700'
          }`}>
            {action.label}
          </a>
        </div>
      )}
    </div>
  </div>
</section>

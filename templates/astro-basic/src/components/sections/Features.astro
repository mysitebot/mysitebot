---
import { resolvePath } from '../../utils/paths';
import Button from '../ui/Button.astro';

/**
 * Features Component - A responsive grid (or full-width list) of feature cards,
 * each with a title, description, and an icon, image, or built-in named icon.
 * Ideal for highlighting product benefits, services, or capabilities. Supports
 * per-feature CTAs and an optional section-level action button.
 */
interface Props {
  /** Optional anchor id for in-page links (e.g. href="#features") */
  id?: string;
  heading?: string;
  subheading?: string;
  columns?: 2 | 3 | 4;
  /** Layout variant: 'grid' for multi-column card grid (default), 'list' for full-width stacked rows */
  layout?: 'grid' | 'list';
  backgroundColor?: string;
  /** Background image URL — creates a full-cover background behind the features grid */
  backgroundImage?: string;
  /** Base text color applied to heading, subheading, and feature titles/descriptions (Tailwind class, e.g. 'text-white'). Use when backgroundColor is dark. */
  textColor?: string;
  /** Override color for the section heading only (Tailwind class, e.g. 'text-yellow-600'). Takes precedence over textColor for the h2 element. */
  headingColor?: string;
  /** Text alignment for the section header and feature card content: 'center' (default), 'left', or 'right' */
  align?: 'left' | 'center' | 'right';
  /** Optional section-level CTA button rendered below the features grid */
  action?: { label: string; href: string; variant?: 'primary' | 'secondary' | 'success'; };
  features: Array<{
    title: string;
    description: string;
    /** Optional bulleted list rendered between the title and the description (e.g. a short catalog or list of items) */
    bulletPoints?: string[];
    /** Name of a built-in outline icon: 'bolt', 'check', 'shield', 'star', 'heart', 'chart', 'globe', 'users', 'cog', 'clock', 'lock', 'rocket', 'sparkles', 'cloud', 'lightbulb', 'chat', 'mail', 'phone'. Falls back to 'bolt' when omitted or unrecognized. Ignored when 'image' is set. */
    icon?: string;
    image?: string;
    backgroundColor?: string;
    /** Override color for this feature's title only (Tailwind class, e.g. 'text-red-500'). Takes precedence over textColor for the h3 element. */
    headingColor?: string;
    /** Optional CTA button shown below the description */
    action?: { label: string; href: string; variant?: 'primary' | 'secondary' | 'success'; };
  }>;
}

const {
  id,
  heading,
  subheading,
  columns = 3,
  layout = 'grid',
  backgroundColor = 'bg-white',
  backgroundImage,
  textColor,
  headingColor,
  align = 'center',
  action,
  features = []
} = Astro.props;

const alignmentClasses = {
  center: 'text-center',
  left: 'text-left',
  right: 'text-right'
};

const gridCols = layout === 'list'
  ? 'grid-cols-1'
  : ({
      2: 'md:grid-cols-2',
      3: 'md:grid-cols-2 lg:grid-cols-3',
      4: 'md:grid-cols-2 lg:grid-cols-4'
    }[columns] ?? 'md:grid-cols-2 lg:grid-cols-3');

// Built-in outline icons, drawn on a 24×24 viewBox with the same stroke styling
// as the default bolt. Each entry is a list of <path> `d` values so multi-stroke
// glyphs (e.g. cog, shield) render correctly.
const ICONS: Record<string, string[]> = {
  bolt: ['M13 10V3L4 14h7v7l9-11h-7z'],
  check: ['M5 13l4 4L19 7'],
  shield: ['M9 12l2 2 4-4', 'M12 3l7 3v5c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6l7-3z'],
  star: ['M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z'],
  heart: ['M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z'],
  chart: ['M13 7h8m0 0v8m0-8l-8 8-4-4-6 6'],
  globe: ['M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9'],
  users: ['M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z'],
  cog: ['M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z', 'M15 12a3 3 0 11-6 0 3 3 0 016 0z'],
  clock: ['M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'],
  lock: ['M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z'],
  rocket: ['M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.63 8.41m5.96 5.96a14.93 14.93 0 01-5.84 2.58m-.12-8.54a6 6 0 00-7.38 5.84h4.8m2.58-5.84a14.93 14.93 0 00-2.58 5.84M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z'],
  sparkles: ['M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z'],
  cloud: ['M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z'],
  lightbulb: ['M9.663 17h4.673M12 3a6 6 0 00-3.75 10.687c.37.29.582.73.582 1.2V16a1 1 0 001 1h4.336a1 1 0 001-1v-1.113c0-.47.212-.91.582-1.2A6 6 0 0012 3z'],
  chat: ['M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z'],
  mail: ['M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'],
  phone: ['M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'],
};

// Friendly aliases so common synonyms resolve to a built-in glyph.
const ICON_ALIASES: Record<string, string> = {
  lightning: 'bolt', flash: 'bolt', zap: 'bolt',
  checkmark: 'check', tick: 'check', done: 'check',
  security: 'lock', 'shield-check': 'shield',
  people: 'users', team: 'users', community: 'users',
  settings: 'cog', gear: 'cog',
  growth: 'chart', trending: 'chart', analytics: 'chart',
  world: 'globe', international: 'globe',
  time: 'clock', speed: 'clock',
  idea: 'lightbulb', innovation: 'lightbulb',
  message: 'chat', support: 'chat',
  email: 'mail', call: 'phone',
  favorite: 'heart', love: 'heart',
};

const resolveIcon = (name?: string): string[] => {
  if (!name) return ICONS.bolt;
  const key = name.toLowerCase().trim();
  return ICONS[key] ?? ICONS[ICON_ALIASES[key]] ?? ICONS.bolt;
};
---

<section
  id={id}
  class={`py-24 px-6 ${backgroundImage ? 'bg-cover bg-center' : backgroundColor} ${textColor || ''}`}
  style={backgroundImage ? `background-image: url('${backgroundImage}')` : undefined}
>
  <div class="max-w-7xl mx-auto">
    {(heading || subheading) && (
      <div class={`${alignmentClasses[align]} mb-20`}>
        {heading && <h2 class={`text-4xl font-bold mb-4 ${headingColor || textColor || 'text-gray-900'}`}>{heading}</h2>}
        {subheading && <p class={`text-lg max-w-2xl ${align === 'center' ? 'mx-auto' : (align === 'right' ? 'ml-auto' : '')} ${textColor || 'text-gray-500'}`}>{subheading}</p>}
      </div>
    )}

    <div class={`grid grid-cols-1 ${gridCols} gap-12`}>
      {features.map(feature => (
        <div class={`group ${layout === 'list' ? 'flex gap-6 items-start' : 'p-8 rounded-2xl'} ${alignmentClasses[align]} ${feature.backgroundColor || ''}`}>
          {layout === 'list' ? (
            <>
              {feature.image ? (
                <img src={resolvePath(feature.image)} alt={feature.title} class="w-24 h-24 object-cover rounded-xl shrink-0" />
              ) : (
                <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-indigo-600 group-hover:text-white transition-colors duration-300">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                    {resolveIcon(feature.icon).map(d => (
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={d} />
                    ))}
                  </svg>
                </div>
              )}
              <div>
                <h3 class={`text-xl font-bold mb-3 ${feature.headingColor || textColor || 'text-gray-900'}`}>{feature.title}</h3>
                {feature.bulletPoints && feature.bulletPoints.length > 0 && (
                  <ul class={`list-disc pl-5 mb-3 space-y-1 ${textColor || 'text-gray-600'}`}>
                    {feature.bulletPoints.map(point => (<li>{point}</li>))}
                  </ul>
                )}
                <p class={`leading-relaxed ${textColor || 'text-gray-500'}`}>{feature.description}</p>
                {feature.action && (
                  <div class="mt-4">
                    {/* Button resolves the base path itself. */}
                    <Button href={feature.action.href} variant={feature.action.variant || 'primary'}>
                      {feature.action.label}
                    </Button>
                  </div>
                )}
              </div>
            </>
          ) : (
            <>
              {feature.image ? (
                <img src={resolvePath(feature.image)} alt={feature.title} class="w-full h-48 object-cover rounded-xl mb-6" />
              ) : (
                <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-colors duration-300">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                    {resolveIcon(feature.icon).map(d => (
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={d} />
                    ))}
                  </svg>
                </div>
              )}
              <h3 class={`text-xl font-bold mb-3 ${feature.headingColor || textColor || 'text-gray-900'}`}>{feature.title}</h3>
              {feature.bulletPoints && feature.bulletPoints.length > 0 && (
                <ul class={`list-disc pl-5 mb-3 space-y-1 inline-block text-left ${textColor || 'text-gray-600'}`}>
                  {feature.bulletPoints.map(point => (<li>{point}</li>))}
                </ul>
              )}
              <p class={`leading-relaxed ${textColor || 'text-gray-500'}`}>{feature.description}</p>
              {feature.action && (
                <div class="mt-6">
                  {/* Button resolves the base path itself. */}
                  <Button href={feature.action.href} variant={feature.action.variant || 'primary'}>
                    {feature.action.label}
                  </Button>
                </div>
              )}
            </>
          )}
        </div>
      ))}
    </div>

    {action && (
      <div class={`mt-12 ${alignmentClasses[align]}`}>
        {/* Button resolves the base path itself. */}
        <Button href={action.href} variant={action.variant || 'primary'}>
          {action.label}
        </Button>
      </div>
    )}
  </div>
</section>

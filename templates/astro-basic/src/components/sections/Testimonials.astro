---
import { resolvePath } from '../../utils/paths';

/**
 * Testimonials Component - Social proof from customers, rendered as an
 * accessible card grid (default) or an alternating text/image split layout.
 * Each quote is marked up as a <figure>/<blockquote> with its author in the
 * <figcaption>, and avatars fall back to a lettered monogram when no image is
 * supplied. Set `showRating` to display a star rating per testimonial; each
 * item's `rating` (1–5, default 5) drives how many stars are filled.
 */
interface Props {
  /** Optional anchor id for in-page links (e.g. href="#testimonials") */
  id?: string;
  heading?: string;
  /** Supporting description shown below the heading */
  subheading?: string;
  /** Background color for the outer section (Tailwind class, e.g. 'bg-white') */
  backgroundColor?: string;
  /** Base text color applied to heading and subheading (Tailwind class, e.g. 'text-white'). Use when backgroundColor is dark. */
  textColor?: string;
  /** Override color for the section heading only (Tailwind class, e.g. 'text-red-600'). Takes precedence over textColor for the h2 element. */
  headingColor?: string;
  /** Layout variant: 'grid' for card grid (default), 'split' for left-text right-image */
  layout?: 'grid' | 'split';
  /** Number of columns in the card grid (default: 3). Only applies when layout='grid'. */
  columns?: 2 | 3 | 4;
  /** Tailwind max-width class constraining the inner content container (e.g. 'max-w-2xl', 'max-w-4xl'). Defaults to 'max-w-7xl'. */
  maxWidth?: string;
  /** Text alignment for heading and subheading: 'center' (default), 'left', or 'right' */
  align?: 'left' | 'center' | 'right';
  /** Show a 5-star rating per testimonial (default: true). Set false to hide stars entirely. */
  showRating?: boolean;
  testimonials: Array<{
    quote: string;
    author: string;
    role?: string;
    avatar?: string;
    /** Star rating from 1 to 5 (default 5). Only shown when showRating is true. */
    rating?: number;
    image?: { src: string; alt: string; };
  }>;
}

const { id, heading = "Trusted by businesses worldwide", subheading, backgroundColor = "bg-gray-50", textColor, headingColor, layout = 'grid', columns = 3, maxWidth = 'max-w-7xl', align = 'center', showRating = true, testimonials = [] } = Astro.props;
const textAlignClass = align === 'left' ? 'text-left' : align === 'right' ? 'text-right' : 'text-center';
const gridCols = columns === 2 ? 'lg:grid-cols-2' : columns === 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3';
const initial = (name: string) => (name?.trim()?.[0] ?? '').toUpperCase();
// Clamp any supplied rating to a whole number of stars in the 1–5 range,
// defaulting to a full 5 when the field is omitted.
const starCount = (rating?: number) => Math.max(1, Math.min(5, Math.round(rating ?? 5)));
---

<section id={id} class={`py-24 px-6 ${backgroundColor} ${textColor ?? ''}`}>
  <div class={`${maxWidth} mx-auto`}>
    {heading && <h2 class={`text-4xl font-bold mb-4 ${textAlignClass} ${headingColor || textColor || 'text-gray-900'}`}>{heading}</h2>}
    {subheading && <p class={`text-lg ${textAlignClass} mb-12 ${textColor ?? 'text-gray-600'}`}>{subheading}</p>}

    {layout === 'split' ? (
      <div class="space-y-16">
        {testimonials.map((item, idx) => (
          <figure class={`flex flex-col md:flex-row gap-8 items-center ${idx % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
            <div class="w-full md:w-1/2">
              {showRating && (
                <div class="flex mb-4" role="img" aria-label={`Rated ${starCount(item.rating)} out of 5`}>
                  {[...Array(5)].map((_, i) => (
                    <svg class={`h-5 w-5 fill-current ${i < starCount(item.rating) ? 'text-indigo-400' : 'text-gray-200'}`} viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                </div>
              )}
              <blockquote class="text-gray-600 italic mb-6 text-lg leading-relaxed before:content-['“'] after:content-['”']">{item.quote}</blockquote>
              <figcaption class="flex items-center">
                {item.avatar ? (
                  <img src={resolvePath(item.avatar)} alt={`Portrait of ${item.author}`} loading="lazy" decoding="async" class="w-12 h-12 rounded-full mr-4 object-cover" />
                ) : (
                  <div aria-hidden="true" class="w-12 h-12 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold mr-4">
                    {initial(item.author)}
                  </div>
                )}
                <div>
                  <p class="font-bold text-gray-900 not-italic">{item.author}</p>
                  {item.role && <p class="text-xs text-gray-500 uppercase tracking-wider">{item.role}</p>}
                </div>
              </figcaption>
            </div>
            {item.image && (
              <div class="w-full md:w-1/2">
                <img src={resolvePath(item.image.src)} alt={item.image.alt} loading="lazy" decoding="async" class="w-full h-64 object-cover rounded-2xl" />
              </div>
            )}
          </figure>
        ))}
      </div>
    ) : (
      <ul role="list" class={`grid grid-cols-1 md:grid-cols-2 ${gridCols} gap-8`}>
        {testimonials.map(item => (
          <li>
            <figure class="h-full bg-white p-8 rounded-3xl shadow-sm border border-gray-100 flex flex-col transition-shadow duration-300 hover:shadow-lg">
              <div class="flex-grow">
                {showRating && (
                  <div class="flex mb-4" role="img" aria-label={`Rated ${starCount(item.rating)} out of 5`}>
                    {[...Array(5)].map((_, i) => (
                      <svg class={`h-5 w-5 fill-current ${i < starCount(item.rating) ? 'text-indigo-400' : 'text-gray-200'}`} viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    ))}
                  </div>
                )}
                <blockquote class="text-gray-600 italic mb-8 leading-relaxed before:content-['“'] after:content-['”']">{item.quote}</blockquote>
              </div>
              <figcaption class="flex items-center mt-6">
                {item.avatar ? (
                  <img src={resolvePath(item.avatar)} alt={`Portrait of ${item.author}`} loading="lazy" decoding="async" class="w-12 h-12 rounded-full mr-4 object-cover" />
                ) : (
                  <div aria-hidden="true" class="w-12 h-12 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold mr-4">
                    {initial(item.author)}
                  </div>
                )}
                <div>
                  <p class="font-bold text-gray-900 not-italic">{item.author}</p>
                  {item.role && <p class="text-xs text-gray-500 uppercase tracking-wider">{item.role}</p>}
                </div>
              </figcaption>
            </figure>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

---
import { resolvePath } from '../../utils/paths';
/**
 * NewsGrid Component - Displays multiple columns of news or content articles.
 * Each column has a heading and contains a list of article cards.
 * Optionally renders a sidebar (e.g. category list, archives, recent comments)
 * beside the grid, on the left (default) or right via sidebarPosition.
 */
interface Props {
  /** Optional anchor id for in-page links (e.g. href="#news") */
  id?: string;
  /** Background color for the outer section (Tailwind class, e.g. 'bg-gray-100') */
  backgroundColor?: string;
  /** Text color for headings and labels (Tailwind class, e.g. 'text-white') */
  textColor?: string;
  /** Overall section heading displayed above the columns */
  heading?: string;
  /** Supporting description shown below the section heading */
  subheading?: string;
  /** Number of columns in the news grid area */
  columns?: 2 | 3 | 4;
  /** Text alignment for heading and subheading: 'center' (default), 'left', or 'right' */
  align?: 'left' | 'center' | 'right';
  /** Optional sidebar rendered beside the news grid (position controlled by sidebarPosition) */
  sidebar?: {
    /** Sidebar heading (e.g. "Categories") for the primary item list */
    heading?: string;
    /** List of sidebar item labels for the primary widget */
    items?: string[];
    /** Additional sidebar widgets, each rendered as its own card (e.g. "Archives", "Recent Comments") */
    sections?: Array<{
      heading?: string;
      items: string[];
    }>;
  };
  /** Which side to render the sidebar: 'left' (default) or 'right' */
  sidebarPosition?: 'left' | 'right';
  /** Array of column sections, each with a heading and articles */
  sections: Array<{
    heading: string;
    articles: Array<{
      title: string;
      description?: string;
      image?: { src: string; alt: string };
      action?: { label: string; href: string };
    }>;
  }>;
}

const {
  id,
  backgroundColor = 'bg-gray-100',
  textColor = 'text-gray-900',
  heading,
  subheading,
  columns = 3,
  align = 'center',
  sidebar,
  sidebarPosition = 'left',
  sections = []
} = Astro.props;

// Flatten the sidebar into a list of widget cards: an optional primary list
// (heading + items) followed by any extra sections. Keeps single-widget
// usages working while allowing stacked widgets like "Archives" + "Recent Comments".
const sidebarWidgets = sidebar
  ? [
      ...(sidebar.items && sidebar.items.length > 0
        ? [{ heading: sidebar.heading, items: sidebar.items }]
        : []),
      ...(sidebar.sections ?? [])
    ]
  : [];
const hasSidebar = sidebarWidgets.length > 0;
const sidebarOnRight = sidebarPosition === 'right';

const gridCols = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-2 lg:grid-cols-3',
  4: 'md:grid-cols-2 lg:grid-cols-4'
}[columns];

const alignClass = align === 'left' ? 'text-left' : align === 'right' ? 'text-right' : 'text-center';
---

<section id={id} class={`py-24 px-6 ${backgroundColor}`}>
  <div class="max-w-7xl mx-auto">
    {(heading || subheading) && (
      <div class={`mb-14 ${alignClass}`}>
        {heading && <h2 class={`text-4xl font-bold tracking-tight mb-4 ${textColor}`}>{heading}</h2>}
        {subheading && <p class={`text-lg ${textColor} opacity-70 ${align === 'center' ? 'max-w-2xl mx-auto' : ''}`}>{subheading}</p>}
      </div>
    )}
    <div class={hasSidebar ? 'flex flex-col lg:flex-row gap-10' : ''}>
      {hasSidebar && (
        <aside class={`w-full lg:w-72 lg:flex-shrink-0 space-y-6 ${sidebarOnRight ? 'lg:order-2' : ''}`}>
          {sidebarWidgets.map(widget => (
            <div class="bg-white rounded-3xl p-6 border border-gray-100 shadow-sm lg:sticky lg:top-8">
              {widget.heading && <h3 class={`text-lg font-bold mb-4 ${textColor}`}>{widget.heading}</h3>}
              <ul role="list" class="space-y-1">
                {widget.items.map(item => (
                  <li>
                    <span class="flex items-center gap-3 rounded-xl px-3 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-indigo-50 hover:text-indigo-700">
                      <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-indigo-400"></span>
                      {item}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </aside>
      )}
      <div class={hasSidebar ? `flex-1 min-w-0 ${sidebarOnRight ? 'lg:order-1' : ''}` : ''}>
        <div class={`grid grid-cols-1 ${gridCols} gap-8`}>
          {sections.map(section => (
            <div>
              <h3 class={`text-sm font-semibold uppercase tracking-wider mb-6 pb-3 border-b border-gray-200 ${textColor}`}>{section.heading}</h3>
              <div class="space-y-6">
                {section.articles.map(article => (
                  <article class="group bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden transition duration-300 hover:shadow-md hover:-translate-y-0.5 focus-within:ring-2 focus-within:ring-indigo-500/40">
                    {article.image && (
                      <div class="aspect-[16/9] overflow-hidden bg-gray-100">
                        <img
                          src={resolvePath(article.image.src)}
                          alt={article.image.alt}
                          loading="lazy"
                          decoding="async"
                          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                      </div>
                    )}
                    <div class="p-5">
                      <h4 class="text-lg font-bold text-gray-900 mb-2 leading-snug">{article.title}</h4>
                      {article.description && (
                        <p class="text-gray-500 text-sm leading-relaxed mb-4">{article.description}</p>
                      )}
                      {article.action && (
                        <a href={resolvePath(article.action.href)} class="inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-600 transition-colors hover:text-indigo-800 focus:outline-none">
                          {article.action.label}
                          <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                          </svg>
                        </a>
                      )}
                    </div>
                  </article>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

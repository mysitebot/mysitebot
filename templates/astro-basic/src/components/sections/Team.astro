---
import { resolvePath } from '../../utils/paths';

/**
 * Team Component - Showcases key staff members or contributors.
 * Use this to build trust and humanize the brand. Each member card can
 * optionally surface social profile links (LinkedIn, X/Twitter, GitHub, and a
 * personal website), rendered as accessible icon buttons.
 */
interface Props {
  /** Optional ID for anchor linking */
  id?: string;
  /** Background color for the outer section (Tailwind class, e.g., 'bg-white') */
  backgroundColor?: string;
  /** Base text color for heading and body text (Tailwind class, e.g., 'text-white') */
  textColor?: string;
  /** Horizontal alignment of the section header: 'center' (default), 'left', or 'right' */
  align?: 'left' | 'center' | 'right';
  /** Number of columns in the grid layout (2, 3, or 4; default: 4) */
  columns?: 2 | 3 | 4;
  /** Section heading */
  heading?: string;
  /** Supporting description */
  subheading?: string;
  /** Array of team members */
  members: Array<{
    /** Full name of the member */
    name: string;
    /** Job title or role */
    role: string;
    /** Short biography */
    bio?: string;
    /** URL to the member's profile picture */
    avatar?: string;
    /** URL to the member's LinkedIn profile */
    linkedin?: string;
    /** URL to the member's X (Twitter) profile */
    twitter?: string;
    /** URL to the member's GitHub profile */
    github?: string;
    /** URL to the member's personal website */
    website?: string;
  }>;
}

const { id, backgroundColor = 'bg-gray-50', textColor = 'text-gray-900', align = 'center', columns = 4, heading, subheading, members = [] } = Astro.props;
const alignClass = align === 'left' ? 'text-left' : align === 'right' ? 'text-right' : 'text-center';
const gridColsClass = columns === 2 ? 'lg:grid-cols-2' : columns === 3 ? 'lg:grid-cols-3' : 'lg:grid-cols-4';

// Ordered social links keyed by member field, each with an accessible verb and
// an inline SVG path so the markup stays dependency-free.
const SOCIALS = [
  { key: 'linkedin', label: 'LinkedIn', path: 'M4.98 3.5C4.98 4.88 3.87 6 2.5 6S.02 4.88.02 3.5C.02 2.12 1.13 1 2.5 1s2.48 1.12 2.48 2.5zM.25 8h4.5v13H.25V8zm7.5 0h4.31v1.78h.06c.6-1.14 2.07-2.34 4.26-2.34C21.1 7.44 22 10 22 13.34V21h-4.5v-6.78c0-1.62-.03-3.7-2.25-3.7-2.26 0-2.6 1.76-2.6 3.58V21h-4.5V8z' },
  { key: 'twitter', label: 'X', path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { key: 'github', label: 'GitHub', path: 'M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 015.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14 0 1.55-.01 2.79-.01 3.17 0 .31.21.68.8.56A11.51 11.51 0 0023.5 12C23.5 5.73 18.27.5 12 .5z' },
  { key: 'website', label: 'Website', path: 'M12 2a10 10 0 100 20 10 10 0 000-20zm6.93 6h-2.95a15.7 15.7 0 00-1.38-3.56A8.03 8.03 0 0118.93 8zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14a7.96 7.96 0 010-4h3.38a16.6 16.6 0 000 4H4.26zm.81 2h2.95c.32 1.25.79 2.45 1.38 3.56A8.03 8.03 0 015.07 16zm2.95-8H5.07a8.03 8.03 0 014.33-3.56A15.7 15.7 0 008.02 8zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66a14.8 14.8 0 010-4h4.68a14.8 14.8 0 010 4zm.27 5.56c.59-1.11 1.06-2.31 1.38-3.56h2.95a8.03 8.03 0 01-4.33 3.56zM16.36 14a16.6 16.6 0 000-4h3.38a7.96 7.96 0 010 4h-3.38z' },
] as const;

const memberSocials = (member: Props['members'][number]) =>
  SOCIALS
    .map(s => ({ ...s, href: member[s.key] }))
    .filter((s): s is typeof s & { href: string } => Boolean(s.href));
---

<section id={id} class={`py-24 px-6 ${backgroundColor}`}>
  <div class="max-w-7xl mx-auto">
    {(heading || subheading) && (
      <div class={`${alignClass} mb-20`}>
        {heading && <h2 class={`text-4xl font-bold mb-4 ${textColor}`}>{heading}</h2>}
        {subheading && <p class={`text-lg max-w-2xl mx-auto opacity-70 ${textColor}`}>{subheading}</p>}
      </div>
    )}

    <ul role="list" class={`grid grid-cols-1 md:grid-cols-2 ${gridColsClass} gap-8`}>
      {members.map(member => {
        const socials = memberSocials(member);
        return (
        <li class="group relative flex flex-col bg-white rounded-3xl p-8 border border-gray-100 shadow-sm transition duration-300 hover:shadow-md hover:-translate-y-1 focus-within:ring-2 focus-within:ring-indigo-500/40">
          <div class="mb-6">
            {member.avatar ? (
              <img src={resolvePath(member.avatar)} alt={`Portrait of ${member.name}`} loading="lazy" decoding="async" class="w-24 h-24 rounded-2xl object-cover mx-auto shadow-sm ring-4 ring-transparent transition duration-300 group-hover:ring-indigo-100" />
            ) : (
              <div aria-hidden="true" class="w-24 h-24 rounded-2xl bg-indigo-100 flex items-center justify-center mx-auto ring-4 ring-transparent transition duration-300 group-hover:ring-indigo-50">
                <span class="text-indigo-600 font-bold text-2xl">{(member.name?.trim()?.[0] ?? '').toUpperCase()}</span>
              </div>
            )}
          </div>
          <div class="text-center flex-grow">
            <h3 class="text-xl font-bold text-gray-900 mb-1">{member.name}</h3>
            <p class="text-indigo-600 font-semibold text-sm mb-4">{member.role}</p>
            {member.bio && <p class="text-gray-500 text-sm leading-relaxed">{member.bio}</p>}
          </div>
          {socials.length > 0 && (
            <ul role="list" class="flex items-center justify-center gap-2 mt-6 pt-6 border-t border-gray-100">
              {socials.map(social => (
                <li>
                  <a
                    href={social.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${member.name} on ${social.label}`}
                    class="inline-flex h-9 w-9 items-center justify-center rounded-full text-gray-400 transition-colors duration-200 hover:bg-indigo-50 hover:text-indigo-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500/50"
                  >
                    <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path d={social.path} />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
        );
      })}
    </ul>
  </div>
</section>
